{
  "name": "@tainnel/hub",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "tainnel hub service: 1-hop HTLC routing, channel pool, dispute handling.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.1",
    "@tainnel/protocol": "workspace:*",
    "@tainnel/sdk": "workspace:*",
    "@tainnel/state-machine": "workspace:*",
    "better-sqlite3": "^11.5.0",
    "fastify": "^5.1.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  }
}
