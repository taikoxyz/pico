# Copy to .env and replace placeholders before starting.
# CHAIN_ID=167000 means Taiko mainnet. Use 31337 for local anvil dev.
PORT=3030
LOG_LEVEL=info

# CRITICAL: HUB_PRIVATE_KEY MUST be a real key on non-anvil chains.
# A well-known development key (such as 0x...0001) is rejected at startup
# unless CHAIN_ID=31337. Generate via `cast wallet new` or your KMS.
HUB_PRIVATE_KEY=replace-me

# CRITICAL: required on mainnet to prevent open operator REST endpoints.
HUB_OPERATOR_TOKEN=replace-me

# CRITICAL: required on mainnet so WebSocket clients must produce signed envelopes.
HUB_REQUIRE_SIGNED_ENVELOPE=true

RPC_URL=https://rpc.mainnet.taiko.xyz
DB_DRIVER=sqlite
DB_URL=./data/hub.sqlite
PROMETHEUS_PORT=9090

# For anvil local-dev only — DO NOT set these on real networks:
# CHAIN_ID=31337
# TAINNEL_DEV_ALLOW_ZERO_ADDRESS=true
