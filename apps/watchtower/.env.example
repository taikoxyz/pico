# Copy to .env and replace placeholders before starting.
# CHAIN_ID=167000 → Taiko mainnet, CHAIN_ID=1 → Ethereum mainnet, CHAIN_ID=31337 → local anvil dev.
PORT=3031
LOG_LEVEL=info

# CRITICAL: WATCHTOWER_PRIVATE_KEY MUST be a real key on non-anvil chains.
# Well-known development keys (e.g. 0x...0002) are rejected at startup.
WATCHTOWER_PRIVATE_KEY=replace-me

# Taiko mainnet: https://rpc.mainnet.taiko.xyz
# Ethereum mainnet: set to your Ethereum JSON-RPC endpoint (e.g. Alchemy/Infura)
RPC_URL=https://rpc.mainnet.taiko.xyz
DB_URL=./data/watchtower.sqlite
METRICS_BIND_ADDR=127.0.0.1

# v1 only ships self-hosted mode. MODE=service is rejected at startup.
MODE=self-hosted

# For anvil local-dev only — DO NOT set on real networks:
# CHAIN_ID=31337
# PICO_DEV_ALLOW_ZERO_ADDRESS=true

# Ethereum mainnet — set contract address after deployment:
# CHAIN_ID=1
# PAYMENT_CHANNEL_ADDRESS=<deployed proxy address>
