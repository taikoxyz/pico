{
  "name": "@inferenceroom/pico-watchtower",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "pico watchtower service: detects fraudulent old-state submissions and submits penalty transactions.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@inferenceroom/pico-protocol": "workspace:*",
    "@inferenceroom/pico-sdk": "workspace:*",
    "@inferenceroom/pico-state-machine": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.1.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "viem": "^2.49.0"
  },
  "devDependencies": {
    "@inferenceroom/pico-hub": "workspace:*",
    "@inferenceroom/pico-test-utils": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
