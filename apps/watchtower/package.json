{
  "name": "@tainnel/watchtower",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "tainnel watchtower service: detects fraudulent old-state submissions and submits penalty transactions.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@tainnel/protocol": "workspace:*",
    "@tainnel/state-machine": "workspace:*",
    "better-sqlite3": "^11.5.0",
    "pino": "^9.5.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
