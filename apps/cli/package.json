{
  "name": "@inferenceroom/pico-cli",
  "version": "2.1.1",
  "license": "MIT",
  "description": "pico developer/operator CLI: open and close channels, pay, query hubs, run dev fork.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "pico": "./dist/index.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/generate-versions.mjs && tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.1.3",
    "prompts": "^2.4.2",
    "viem": "^2.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@inferenceroom/pico-dvm-adapter": "workspace:*",
    "@inferenceroom/pico-protocol": "workspace:*",
    "@inferenceroom/pico-sdk": "workspace:*",
    "@inferenceroom/pico-state-machine": "workspace:*",
    "@inferenceroom/pico-test-utils": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.9",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
