{
  "name": "@pico/cli",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "pico developer/operator CLI: open and close channels, pay, query hubs, run dev fork.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "pico": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@pico/dvm-adapter": "workspace:*",
    "@pico/protocol": "workspace:*",
    "@pico/sdk": "workspace:*",
    "@pico/state-machine": "workspace:*",
    "@pico/test-utils": "workspace:*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "prompts": "^2.4.2",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
