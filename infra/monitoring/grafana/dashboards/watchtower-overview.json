        {"expr": "tainnel_watchtower_channels_watched", "refId": "A"}
      ],
      "options": {"reduceOptions": {"calcs": ["last"], "fields": "", "values": false}, "colorMode": "value"},
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 6}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "RPC up",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "tainnel_watchtower_rpc_up", "refId": "A"}
      ],
      "options": {"reduceOptions": {"calcs": ["last"], "fields": "", "values": false}, "colorMode": "background"},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 6}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Penalties submitted (cumulative)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "tainnel_watchtower_penalties_submitted_total", "refId": "A"}
      ],
      "options": {"reduceOptions": {"calcs": ["last"], "fields": "", "values": false}, "colorMode": "value"},
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 6}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Evaluations by result (rate 5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
