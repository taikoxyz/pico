{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["tsconfig.base.json", "biome.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "out/**", "build/**", ".next/**", "!**/node_modules/**"]
    },
    "@tainnel/sdk#build": {
      "dependsOn": ["@tainnel/protocol#build", "@tainnel/state-machine#build"],
      "outputs": ["dist/**", "!**/node_modules/**"]
    },
    "@tainnel/sdk#typecheck": {
      "dependsOn": ["@tainnel/protocol#build", "@tainnel/state-machine#build"],
      "outputs": []
    },
    "@tainnel/sdk#test": {
      "dependsOn": [
        "@tainnel/protocol#build",
        "@tainnel/state-machine#build",
        "@tainnel/test-utils#build"
      ],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
