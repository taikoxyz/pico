{
  "name": "@tainnel/e2e",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "Cross-package end-to-end tests: spins up anvil + forge deploy + hub + watchtower.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@tainnel/hub": "workspace:*",
    "@tainnel/protocol": "workspace:*",
    "@tainnel/sdk": "workspace:*",
    "@tainnel/state-machine": "workspace:*",
    "@tainnel/test-utils": "workspace:*",
    "@tainnel/watchtower": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
