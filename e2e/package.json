{
  "name": "@inferenceroom/pico-e2e",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "Cross-package end-to-end tests: spins up anvil + forge deploy + hub + watchtower.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:fork": "E2E_FORK=1 vitest run scenarios.fork",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@inferenceroom/pico-hub": "workspace:*",
    "@inferenceroom/pico-protocol": "workspace:*",
    "@inferenceroom/pico-sdk": "workspace:*",
    "@inferenceroom/pico-state-machine": "workspace:*",
    "@inferenceroom/pico-test-utils": "workspace:*",
    "@inferenceroom/pico-watchtower": "workspace:*",
    "viem": "^2.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
