    "viem": "^2.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@inferenceroom/pico-state-machine": "workspace:*",
    "@inferenceroom/pico-test-utils": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^2.1.8",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^15.11.7",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
