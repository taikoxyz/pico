    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "@inferenceroom/pico-protocol": "workspace:*",
