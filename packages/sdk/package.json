{
  "name": "@inferenceroom/pico-sdk",
  "version": "2.0.3",
  "private": false,
  "license": "MIT",
  "description": "Browser- and Node-compatible client SDK for opening, paying, and closing pico payment channels.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
