{
  "name": "@tainnel/sdk",
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "description": "Browser- and Node-compatible client SDK for opening, paying, and closing tainnel payment channels.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@tainnel/protocol": "workspace:*",
    "@tainnel/state-machine": "workspace:*",
    "viem": "^2.21.0"
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tainnel/test-utils": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8",
    "ws": "^8.0.0"
  }
}
