{
  "name": "@pico/state-machine",
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "description": "Pure-function state-transition library for pico payment channels.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate:oracle": "tsx test/generate-oracle.ts",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@pico/protocol": "workspace:*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "fast-check": "^3.23.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
