{
  "name": "@inferenceroom/pico-state-machine",
  "version": "2.0.2",
  "private": true,
  "license": "MIT",
  "description": "Pure-function state-transition library for pico payment channels.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate:oracle": "tsx test/generate-oracle.ts",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@inferenceroom/pico-protocol": "workspace:*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "fast-check": "^4.8.0",
    "tsx": "^4.21.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
