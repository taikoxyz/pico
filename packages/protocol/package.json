{
  "name": "@inferenceroom/pico-protocol",
  "version": "2.0.2",
  "private": false,
  "license": "MIT",
  "description": "Shared types, EIP-712 schemas, and constants for the pico state-channel protocol.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "fast-check": "^3.23.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
