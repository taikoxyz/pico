{
  "name": "@inferenceroom/pico-dvm-adapter",
  "version": "2.0.6",
  "private": false,
  "license": "MIT",
  "description": "Helpers for integrating pico channel payments with Nostr DVM events.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@inferenceroom/pico-protocol": "workspace:*",
    "@inferenceroom/pico-sdk": "workspace:*",
    "nostr-tools": "^2.10.4"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
